{
	"name": "kagoj",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"postinstall": "prisma generate && node -e \"require('fs').cpSync('node_modules/pdfjs-dist/build/pdf.worker.min.mjs', 'public/pdf.worker.min.mjs')\"",
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"db:generate": "prisma generate",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"validate": "biome check . && tsc --noEmit"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1030.0",
		"@hookform/resolvers": "^5.2.2",
		"@prisma/adapter-pg": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"@prisma/client-runtime-utils": "^7.7.0",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"howler": "^2.2.4",
		"lucide-react": "^1.8.0",
		"nanoid": "^5.1.7",
		"next": "^16.2.3",
		"next-auth": "^4.24.14",
		"pdfjs-dist": "^5.6.205",
		"pg": "^8.13.1",
		"pino": "^10.3.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.72.1",
		"react-pageflip": "^2.0.3",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/howler": "^2.2.12",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.11.10",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.4",
		"autoprefixer": "^10.5.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.7.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
