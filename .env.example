# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Auth (Auth.js v5) ---
AUTH_SECRET="change-me-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Legacy env var names (NEXTAUTH_SECRET, NEXTAUTH_URL) are accepted in this
# release with a deprecation warning. They will be removed in Phase 2b.

# --- Database ---
DATABASE_URL="postgresql://kagoj:kagoj@localhost:5432/kagoj?schema=public"

# --- Storage ---
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_S3_BUCKET=kagoj
# STORAGE_S3_REGION=auto
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# --- Mailer ---
MAIL_DRIVER=noop                          # resend | noop
MAIL_FROM="Kagoj <noreply@example.com>"   # must match a verified Resend sender (https://resend.com/docs/dashboard/domains/introduction)
MAIL_RESEND_API_KEY=

# --- Verification gating ---
AUTH_REQUIRE_VERIFICATION_FOR_SHARES=true

# --- Logging ---
LOG_LEVEL=info

# --- Rate limit (set to "true" only in CI/test) ---
RATE_LIMIT_DISABLED=false
